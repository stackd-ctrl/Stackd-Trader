# STACKD TRADER — copy to .env.local and fill in.

# --- Supabase ----------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Claude ------------------------------------------------------------------
ANTHROPIC_API_KEY=

# --- Trading mode ------------------------------------------------------------
# 'paper' uses Alpaca paper endpoints; 'live' uses Alpaca production endpoints.
TRADING_MODE=paper

# --- Alpaca ------------------------------------------------------------------
ALPACA_API_KEY_ID=
ALPACA_API_SECRET_KEY=
ALPACA_PAPER_BASE_URL=https://paper-api.alpaca.markets
ALPACA_LIVE_BASE_URL=https://api.alpaca.markets
ALPACA_DATA_BASE_URL=https://data.alpaca.markets
ALPACA_STREAM_STOCKS=wss://stream.data.alpaca.markets/v2/iex
ALPACA_STREAM_CRYPTO=wss://stream.data.alpaca.markets/v1beta3/crypto/us

# --- Polygon -----------------------------------------------------------------
POLYGON_API_KEY=
POLYGON_BASE_URL=https://api.polygon.io

# --- Financial Modeling Prep (economic calendar, free tier) ------------------
FMP_API_KEY=
FMP_BASE_URL=https://financialmodelingprep.com/api/v3

# --- Trade alert emails (Resend) ---------------------------------------------
# Optional. If any of these three are missing, alerts silently no-op.
# TRADE_ALERT_FROM must be on a domain you've verified in Resend.
# IMPORTANT: put real values in .env.local (gitignored), NOT here.
RESEND_API_KEY=
TRADE_ALERT_FROM=alerts@yourdomain.com
TRADE_ALERT_TO=you@example.com
